# ---- Relayer wallet (server-held, funds uploads on Filecoin calibration) ----
# Generate one with: npm run setup:relayer
# (it will write RELAYER_PRIVATE_KEY here on first run)
RELAYER_PRIVATE_KEY=

# ---- Optional: override the default calibration RPC ----
# Default is https://api.calibration.node.glif.io/rpc/v1 (built into the SDK)
FILECOIN_RPC_URL=

# ---- Optional: Vercel KV for cross-instance persistence ----
# When unset, an in-memory store is used (resets on redeploy — fine for a demo)
KV_REST_API_URL=
KV_REST_API_TOKEN=
